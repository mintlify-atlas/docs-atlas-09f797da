  "keyFeatures": [
    "OAuth2 authentication with automatic token refresh",
    "400+ cmdlets covering all CrowdStrike Falcon APIs",
    "Real-time Response automation and batch operations",
    "Comprehensive policy and host group management",
    "Threat intelligence and IOC workflows",
    "Cloud security posture management (AWS, Azure, GCP)",
    "Container and Kubernetes security",
    "MSSP and multi-CID environment support",
    "Built-in filtering, pagination, and error handling",
    "Cross-platform support (Windows, Linux, macOS)"
  ],
